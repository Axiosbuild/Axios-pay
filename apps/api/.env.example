DATABASE_URL=
# Upstash on Railway must use TLS: rediss://default:<password>@<host>:<port>
REDIS_URL=rediss://default:YOUR_PASSWORD@YOUR_UPSTASH_HOST:6379
# Upstash on Railway often needs false; set true only if your runtime supports strict cert validation.
REDIS_TLS_REJECT_UNAUTHORIZED=false
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY_DAYS=30
INTERSWITCH_BASE_URL=
INTERSWITCH_PASSPORT_URL=
INTERSWITCH_CLIENT_ID=
INTERSWITCH_CLIENT_SECRET=
INTERSWITCH_MERCHANT_CODE=
INTERSWITCH_PAY_ITEM_ID=
BASE_URL=https://api-gateway.interswitchng.com

# OTP verification uses the same Interswitch OAuth credentials above.
# No additional OTP-specific environment variables are required.

# Sandbox defaults (recommended for testing wallet funding flow)
# INTERSWITCH_BASE_URL=https://api-gateway.interswitchng.com
# INTERSWITCH_PASSPORT_URL=https://api-gateway.interswitchng.com
# INTERSWITCH_CLIENT_ID=your_sandbox_client_id
# INTERSWITCH_CLIENT_SECRET=your_sandbox_client_secret
# INTERSWITCH_MERCHANT_CODE=your_sandbox_merchant_code
# INTERSWITCH_PAY_ITEM_ID=your_sandbox_pay_item_id
NEXT_PUBLIC_INTERSWITCH_MERCHANT_CODE=
NEXT_PUBLIC_INTERSWITCH_PAY_ITEM_ID=
INTERSWITCH_WEBHOOK_SECRET=
# ── EMAIL (Resend) ─────────────────────────────────────────────────
# Sign up at https://resend.com and create an API key.
# In Railway: add RESEND_API_KEY as an environment variable.
# The sending domain (e.g. axiospay.space) must be verified in the Resend dashboard.
RESEND_API_KEY=re_YOUR_API_KEY
EMAIL_FROM=info@axiospay.space
APP_BASE_URL=http://localhost:8080
VERIFICATION_TOKEN_TTL_MINUTES=15
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
FRONTEND_URL=http://localhost:3000
ENCRYPTION_KEY=
CRON_ENABLED=true
ADMIN_EMAIL=

# ── LIVE FX RATES ──────────────────────────────────────────────────
# ExchangeRate-API (Primary provider)
# Sign up free at: https://www.exchangerate-api.com
# Free tier: 1,500 requests/month
EXCHANGE_RATE_API_KEY=your_key_here

# Frankfurter is free with no key required — no env var needed

# Rate refresh interval in milliseconds (default: 10 minutes)
RATE_REFRESH_INTERVAL_MS=600000

# Axios Pay spread on top of mid-market rate in percent (default: 0.3%)
RATE_SPREAD_PERCENT=0.3

# ── IDENTITY VERIFICATION ──────────────────────────────────────────

# Dojah — Nigerian NIN verification
# Sign up free at: https://dojah.io
# Sandbox NIN for testing: 71234567890
DOJAH_APP_ID=your_app_id
DOJAH_SECRET_KEY=your_secret_key

# Smile Identity — Uganda, Kenya, Ghana, South Africa
# Sign up free at: https://smileidentity.com
# Use SID_SERVER=0 for sandbox, 1 for production
SMILE_IDENTITY_PARTNER_ID=your_partner_id
SMILE_IDENTITY_API_KEY=your_api_key
SMILE_IDENTITY_SID_SERVER=0
