{
  "name": "@axiospay/api",
  "version": "1.0.0",
  "private": true,
  "prisma": {
    "schema": "prisma/schema.prisma"
  },
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "npm run prisma:generate && tsc",
    "postinstall": "npm run prisma:generate",
    "start": "node dist/index.js",
    "deploy": "npm run prisma:generate && npm run prisma:migrate:deploy && npm run start",
    "redis:check": "node scripts/redis-check.js",
    "type-check": "tsc --noEmit",
    "prestart": "npm run prisma:migrate:deploy",
    "prisma:generate": "prisma generate --schema prisma/schema.prisma",
    "prisma:db:push": "prisma db push --schema prisma/schema.prisma",
    "prisma:migrate": "npm run prisma:migrate:deploy",
    "prisma:migrate:deploy": "prisma migrate deploy --schema prisma/schema.prisma"
  },
  "dependencies": {
    "@prisma/client": "^5.14.0",
    "axios": "^1.15.0",
    "bcryptjs": "^2.4.3",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "decimal.js": "^10.4.3",
    "express": "^4.22.1",
    "express-rate-limit": "^7.3.1",
    "helmet": "^7.1.0",
    "ioredis": "^5.4.1",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "nanoid": "^3.3.7",
    "nodemailer": "^8.0.5",
    "otplib": "^12.0.1",
    "prisma": "^5.14.0",
    "qrcode": "^1.5.4",
    "resend": "^4.5.1",
    "twilio": "^5.13.1",
    "uuid": "^13.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/compression": "^1.7.5",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/morgan": "^1.9.9",
    "@types/node": "^18.19.0",
    "@types/qrcode": "^1.5.5",
    "@types/uuid": "^10.0.0",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.4.5"
  }
}
